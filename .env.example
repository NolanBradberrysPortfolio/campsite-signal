# Optional. If unset, the app tries the local codex-anywhere Telegram config.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional email provider.
RESEND_API_KEY=
EMAIL_FROM="Campsite Signal <alerts@example.com>"

# Optional SMS provider.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional server port.
PORT=4173

# Public backend URL used in unsubscribe links inside Telegram/SMS/email messages.
PUBLIC_BASE_URL=https://your-backend.example.com

# Public frontend URL shown after unsubscribing.
APP_BASE_URL=https://your-frontend.example.com
